# Your full production domain
SITE_URL=https://yoursite.onrender.com

# Master API key — protects internal endpoints
API_MASTER_KEY=your_master_key_here

# RapidAPI proxy secret
RAPIDAPI_PROXY_SECRET=your_rapidapi_secret_here

# Ad URLs (optional — leave blank to disable)
AD_DECOY_1_URL=
AD_DECOY_2_URL=
AD_WAIT_URL=

# Set automatically by Render — do not set manually
# PORT=3000
